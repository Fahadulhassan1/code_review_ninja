# ═══════════════════════════════════════════════════════════
#  Agentic Code Review Bot — Environment Variables
# ═══════════════════════════════════════════════════════════

# ── LLM PROVIDER ──────────────────────────────────────────
# Choose your LLM provider (default: groq)
# Supported: groq, openai, anthropic, ollama, gemini
# LLM_PROVIDER=groq

# ── PROVIDER API KEYS (set the one matching your provider) ─

# Groq (free at https://console.groq.com) — DEFAULT
GROQ_API_KEY=gsk_your_api_key_here

# OpenAI (https://platform.openai.com/api-keys)
# OPENAI_API_KEY=sk-your_key_here

# Anthropic (https://console.anthropic.com)
# ANTHROPIC_API_KEY=sk-ant-your_key_here

# Google Gemini (https://aistudio.google.com/apikey)
# GOOGLE_API_KEY=your_key_here

# Ollama — no API key needed, just run `ollama serve` locally
# OLLAMA_BASE_URL=http://localhost:11434

# ── GITHUB ────────────────────────────────────────────────

# GitHub personal access token (for PR integration)
# Create at https://github.com/settings/tokens with 'repo' scope
GITHUB_TOKEN=ghp_your_token_here

# GitHub webhook secret for HMAC-SHA256 signature verification
# GITHUB_WEBHOOK_SECRET=your_secret_here

# ── OPTIONAL ──────────────────────────────────────────────

# Override default model for your provider
# LLM_REASONING_MODEL=llama-3.3-70b-versatile
# LLM_FAST_MODEL=llama-3.3-70b-versatile
# LLM_TIMEOUT_SECONDS=60

# Rate limiting: max requests per minute to Groq API
# GROQ_RATE_LIMIT=25

# GitHub API timeout in seconds
# GITHUB_TIMEOUT_SECONDS=30

# Server configuration
# WEBHOOK_HOST=0.0.0.0
# WEBHOOK_PORT=8000
# LOG_LEVEL=INFO
